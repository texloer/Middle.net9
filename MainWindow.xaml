<Window x:Class="SemiconductorControlSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MidControl" Height="768" Width="1024"
        Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <wv2:WebView2 x:Name="MyWebView" Grid.Row="0" />

        <StatusBar Grid.Row="1" Background="#2D2D2D" Foreground="White">
            <StatusBarItem>
                <!-- 双向绑定：后台更新会自动反映到这里 -->
                <TextBlock x:Name="StatusLabel" Text="{Binding StatusMessage, Mode=OneWay}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>